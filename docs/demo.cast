{"version":3,"term":{"cols":80,"rows":24},"timestamp":1775750470,"command":".venv/bin/python examples/demo_gif.py 2>/dev/null || /Users/olegboiko/Desktop/Agent\\ NEW/avp/.venv/bin/python examples/demo_gif.py","env":{"SHELL":"/bin/zsh"}}
[0.084, "o", "\r\n\u001b[36m  Agent Veil Protocol — SDK Demo\u001b[0m\r\n"]
[0.404, "o", "\u001b[2m  Trust enforcement for autonomous agents\u001b[0m\r\n"]
[0.304, "o", "\u001b[2m  pip install agentveil\u001b[0m\r\n"]
[1.005, "o", "\r\n\u001b[1;37m============================================================\u001b[0m\r\n"]
[0.205, "o", "\u001b[1;37m  [1/4] Create agents with DID identity\u001b[0m\r\n"]
[0.205, "o", "\u001b[1;37m============================================================\u001b[0m\r\n"]
[0.605, "o", "\u001b[2m>>> from agentveil import AVPAgent\u001b[0m\r\n"]
[0.705, "o", "\u001b[2m>>> alice = AVPAgent.create(mock=True, name='alice')\u001b[0m\r\n"]
[0.412, "o", "\u001b[32m  ✓ DID: did:key:z6Mkr9jMeYZnMavkZ76MvX4Knp9sq7VVUmsz77GB...\u001b[0m\r\n"]
[0.505, "o", "\u001b[2m>>> bob = AVPAgent.create(mock=True, name='bob')\u001b[0m\r\n"]
[0.405, "o", "\u001b[32m  ✓ DID: did:key:z6MkjAm1CmpKeEvPMpjYVutVvRpLLp9iMwcyQBr1...\u001b[0m\r\n"]
[0.503, "o", "\u001b[2m>>> alice.register(display_name='Alice — Code Reviewer')\u001b[0m\r\n"]
[0.305, "o", "\u001b[32m  ✓ Registered\u001b[0m\r\n"]
[0.303, "o", "\u001b[2m>>> bob.register(display_name='Bob — Security Auditor')\u001b[0m\r\n"]
[0.305, "o", "\u001b[32m  ✓ Registered\u001b[0m\r\n"]
[0.303, "o", "\u001b[2m>>> alice.publish_card(capabilities=['code_review'], provider='anthropic')\u001b[0m\r\n"]
[0.306, "o", "\u001b[32m  ✓ Card published — discoverable on network\u001b[0m\r\n"]
[1.003, "o", "\r\n\u001b[1;37m============================================================\u001b[0m\r\n"]
[0.203, "o", "\u001b[1;37m  [2/4] Peer attestation — reputation updates instantly\u001b[0m\r\n"]
[0.205, "o", "\u001b[1;37m============================================================\u001b[0m\r\n"]
[0.607, "o", "\u001b[2m>>> alice.attest(bob.did, outcome='positive', weight=0.9, context='code_review')\u001b[0m\r\n"]
[0.500, "o", "\u001b[32m  ✓ Attestation submitted\u001b[0m\r\n"]
[0.501, "o", "\u001b[2m>>> rep = bob.get_reputation()\u001b[0m\r\n"]
[0.405, "o", "\u001b[34m  score: 0.42  confidence: 0.31  tier: basic\u001b[0m\r\n"]
[0.505, "o", "\u001b[34m  tracks: code_quality=0.48  task_completion=0.37\u001b[0m\r\n"]
[0.506, "o", "\u001b[32m  ✓ Score updated immediately after attestation\u001b[0m\r\n"]
[1.204, "o", "\r\n\u001b[1;37m============================================================\u001b[0m\r\n"]
[0.205, "o", "\u001b[1;37m  [3/4] Trust decision — one call\u001b[0m\r\n"]
[0.205, "o", "\u001b[1;37m============================================================\u001b[0m\r\n"]
[0.604, "o", "\u001b[2m>>> alice.can_trust(bob.did, min_tier='trusted')\u001b[0m\r\n"]
[0.505, "o", "\u001b[33m  {\u001b[0m\r\n"]
[0.204, "o", "\u001b[33m    \"allowed\": false,\u001b[0m\r\n"]
[0.306, "o", "\u001b[33m    \"tier\": \"basic\",\u001b[0m\r\n"]
[0.305, "o", "\u001b[33m    \"risk_level\": \"low\",\u001b[0m\r\n"]
[0.305, "o", "\u001b[33m    \"reason\": \"Agent tier basic below required trusted\"\u001b[0m\r\n"]
[0.305, "o", "\u001b[33m  }\u001b[0m\r\n"]
[0.803, "o", "\r\n"]
[0.000, "o", "\u001b[2m>>> alice.can_trust(bob.did, min_tier='basic')\u001b[0m\r\n"]
[0.505, "o", "\u001b[32m  {\u001b[0m\r\n"]
[0.205, "o", "\u001b[32m    \"allowed\": true,\u001b[0m\r\n"]
[0.306, "o", "\u001b[32m    \"tier\": \"basic\",\u001b[0m\r\n"]
[0.300, "o", "\u001b[32m    \"reason\": \"Agent meets basic requirement\"\u001b[0m\r\n"]
[0.305, "o", "\u001b[32m  }\u001b[0m\r\n"]
[0.800, "o", "\r\n\u001b[1;37m  One call. Score + risk + tier + explanation.\u001b[0m\r\n"]
[1.506, "o", "\r\n\u001b[1;37m============================================================\u001b[0m\r\n"]
[0.201, "o", "\u001b[1;37m  [4/4] Sybil resistance — fake agents blocked\u001b[0m\r\n"]
[0.207, "o", "\u001b[1;37m============================================================\u001b[0m\r\n"]
[0.604, "o", "\u001b[2m>>> sybil1 = AVPAgent.create(mock=True, name='sybil1')\u001b[0m\r\n"]
[0.304, "o", "\u001b[2m>>> sybil2 = AVPAgent.create(mock=True, name='sybil2')\u001b[0m\r\n"]
[0.306, "o", "\u001b[33m  sybil1 → sybil2: positive (w=1.0)\u001b[0m\r\n"]
[0.603, "o", "\u001b[33m  sybil2 → sybil1: positive (w=1.0)\u001b[0m\r\n"]
[0.602, "o", "\r\n"]
[0.304, "o", "\u001b[31m  ⚡ Mutual attestation — weight reduced to 0.3x\u001b[0m\r\n"]
[0.804, "o", "\u001b[31m  ⚡ No verified trust paths — flow_score = 0.0\u001b[0m\r\n"]
[0.800, "o", "\u001b[31m  ⚡ Effective reputation: 0.00\u001b[0m\r\n"]
[1.005, "o", "\r\n"]
[0.305, "o", "\u001b[2m>>> alice.can_trust(sybil1.did)\u001b[0m\r\n"]
[0.505, "o", "\u001b[31m  {\"allowed\": false, \"risk_level\": \"critical\"}\u001b[0m\r\n"]
[1.002, "o", "\r\n"]
[0.205, "o", "\u001b[32m  ✓ Honest agents protected. Sybils gated to zero.\u001b[0m\r\n"]
[1.503, "o", "\r\n\u001b[1;37m============================================================\u001b[0m\r\n"]
[0.205, "o", "\u001b[32m  pip install agentveil\u001b[0m\r\n"]
[0.306, "o", "\u001b[32m  https://agentveil.dev\u001b[0m\r\n"]
[0.305, "o", "\u001b[1;37m============================================================\u001b[0m\r\n"]
[0.505, "o", "\r\n"]
[0.033, "x", "0"]
